# 🔑 VARIÁVEIS DE AMBIENTE DA EMMA
# Copie este arquivo para .env e preencha com suas credenciais

# ===== CHAVES DE API =====
# Groq API Keys (obtenha em https://console.groq.com)
GROQ_API_KEY_LLM=sua_chave_groq_aqui
GROQ_API_KEY_VISION=sua_chave_groq_vision_aqui
GROQ_MODEL_DISCORD=meta-llama/llama-4-scout-17b-16e-instruct

# NVIDIA API (Kimi) - obtenha em https://api.nvidia.com
NVIDIA_API_KEY=sua_chave_nvidia_aqui

# Discord Bot Token - obtenha em https://discord.com/developers
DISCORD_BOT_TOKEN=seu_token_discord_aqui

# OpenAI API Key (opcional)
OPENAI_API_KEY=sua_chave_openai_aqui

# ===== CONFIGURAÇÃO DE AMBIENTE =====
# Defina como "true" ao subir para Railway/Heroku/nuvem
RAILWAY_MODE=false

# PORT para Railway (geralmente 8080)
PORT=8080
